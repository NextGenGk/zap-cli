# Supabase project (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, never exposed to the client.
# Used by API routes to validate CLI API keys and write push_events.
SUPABASE_SERVICE_ROLE_KEY=

# Server-side Groq API key for AI commit messages (zap --ai).
# This is the platform's key — end users never need their own.
# Used by /api/ai/commit-message.
GROQ_API_KEY=

# Public base URL of this deployment (used in onboarding + CLI examples)
NEXT_PUBLIC_APP_URL=http://localhost:3000
